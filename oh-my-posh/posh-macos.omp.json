{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": " {{ if .WSL }}WSL/{{ end }}{{ .Icon }} ",
          "foreground": "#ffffff",
          "background": "#61AFEF",
          "properties": {
            "macos": "macOS"
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "template": "  {{ .Path }} ",
          "foreground": "#ffffff",
          "background": "#C678DD",
          "properties": {
            "style": "folder",
            "home_icon": "",
            "folder_icon": "",
            "folder_separator_icon": "  "
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .Staging }}  {{ .Staging }}{{ end }}{{ if .Working }}  {{ .Working }}{{ end }} ",
          "foreground": "#ffffff",
          "background": "#98C379",
          "properties": {
            "branch_icon": " ",
            "commit_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "",
          "template": "  ",
          "foreground": "#ffffff",
          "background": "#E06C75"
        },
        {
          "type": "exit",
          "style": "diamond",
          "trailing_diamond": "",
          "template": " {{ if ne .Code 0 }} {{ .Code }}{{ else }}{{ end }} ",
          "foreground": "#ffffff",
          "background": "#D19A66",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "node",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": "  {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#5C6BC0",
          "properties": {
            "fetch_package_manager": true
          }
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "",
          "template": "  {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#42A5F5"
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "",
          "template": "  {{ .Full }}{{ if .Venv }} ({{ .Venv }}){{ end }} ",
          "foreground": "#ffffff",
          "background": "#FFCB6B"
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "",
          "template": "  {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#DE6E38"
        },
        {
          "type": "java",
          "style": "powerline",
          "powerline_symbol": "",
          "template": "  {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#E53935"
        },
        {
          "type": "time",
          "style": "diamond",
          "trailing_diamond": "",
          "template": "  {{ .CurrentDate | date .Format }} ",
          "foreground": "#ffffff",
          "background": "#56B6C2",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "❯",
          "foreground": "#61AFEF"
        }
      ]
    }
  ]
}
