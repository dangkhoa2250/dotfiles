{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "template": "[{{ if .WSL }}WSL/{{ end }}{{ .Icon }}] ",
          "foreground": "#61AFEF",
          "properties": {
            "macos": ""
          }
        },
        {
          "type": "path",
          "style": "plain",
          "template": "{{ .Path }} ",
          "foreground": "#C678DD",
          "properties": {
            "style": "folder",
            "home_icon": "~",
            "folder_icon": "📁",
            "folder_separator_icon": "/"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "template": "[{{ .HEAD }}{{ if .Staging }} +{{ .Staging }}{{ end }}{{ if .Working }} ~{{ .Working }}{{ end }}] ",
          "foreground": "#98C379",
          "properties": {
            "branch_icon": "🌿 ",
            "fetch_status": true
          }
        },
        {
          "type": "exit",
          "style": "plain",
          "template": "{{ if ne .Code 0 }}❌ {{ .Code }} {{ end }}",
          "foreground": "#E06C75",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "node",
          "style": "plain",
          "template": "🟦 {{ .Full }} ",
          "foreground": "#5C6BC0"
        },
        {
          "type": "go",
          "style": "plain",
          "template": "🐹 {{ .Full }} ",
          "foreground": "#42A5F5"
        },
        {
          "type": "python",
          "style": "plain",
          "template": "🐍 {{ .Full }}{{ if .Venv }} ({{ .Venv }}){{ end }} ",
          "foreground": "#FFCB6B"
        },
        {
          "type": "rust",
          "style": "plain",
          "template": "🦀 {{ .Full }} ",
          "foreground": "#DE6E38"
        },
        {
          "type": "java",
          "style": "plain",
          "template": "☕ {{ .Full }} ",
          "foreground": "#E53935"
        },
        {
          "type": "time",
          "style": "plain",
          "template": "⏰ {{ .CurrentDate | date .Format }} ",
          "foreground": "#56B6C2",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "❯",
          "foreground": "#61AFEF"
        }
      ]
    }
  ]
}
