{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "¯éÂ",
          "trailing_diamond": "",
          "template": " {{ if .WSL }}WSL/{{ end }}{{ .Icon }} ",
          "foreground": "#ffffff",
          "background": "#61AFEF",
          "properties": {
            "windows": "Win"
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ¯ù┐ {{ .Path }} ",
          "foreground": "#ffffff",
          "background": "#C678DD",
          "properties": {
            "style": "folder",
            "home_icon": "´Çò",
            "folder_icon": "´ü╗",
            "folder_separator_icon": " ¯é▒ ",
            "max_depth": 3
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .Staging }} ´üå {{ .Staging }}{{ end }}{{ if .Working }} ´üä {{ .Working }}{{ end }} ",
          "foreground": "#ffffff",
          "background": "#98C379",
          "properties": {
            "branch_icon": "´Éÿ ",
            "commit_icon": "´Éù ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "untracked_modes": {
              "/": "no"
            }
          }
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ´Çí ",
          "foreground": "#ffffff",
          "background": "#E06C75"
        },
        {
          "type": "exit",
          "style": "diamond",
          "trailing_diamond": "¯é┤",
          "template": " {{ if ne .Code 0 }}´Çì {{ .Code }}{{ else }}´Çî{{ end }} ",
          "foreground": "#ffffff",
          "background": "#D19A66",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "battery",
          "style": "diamond",
          "leading_diamond": "¯éÂ",
          "trailing_diamond": "",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Icon }}{{ .Percentage }}{{ end }} ",
          "foreground": "#ffffff",
          "background": "#5C6BC0",
          "properties": {
            "charged_icon": "´û© ",
            "charging_icon": "´âº ",
            "discharging_icon": "´û╣ "
          }
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ¯£ÿ {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#42A5F5",
          "properties": {
            "fetch_package_manager": true
          }
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ¯ÿº {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#98C379"
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ¯£╝ {{ .Full }}{{ if .Venv }} ({{ .Venv }}){{ end }} ",
          "foreground": "#ffffff",
          "background": "#FFCB6B"
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ¯×¿ {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#DE6E38"
        },
        {
          "type": "java",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ¯£© {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#E53935"
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "template": " ¯Ø┐ {{ .Full }} ",
          "foreground": "#ffffff",
          "background": "#6A9955"
        },
        {
          "type": "time",
          "style": "diamond",
          "trailing_diamond": "¯é┤",
          "template": " ´Çù {{ .CurrentDate | date .Format }} ",
          "foreground": "#ffffff",
          "background": "#56B6C2",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "ÔØ»",
          "foreground": "#61AFEF"
        }
      ]
    }
  ]
}
